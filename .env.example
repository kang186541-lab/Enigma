# Local/deployment environment template.
# Copy values into your local .env or your hosting provider's environment settings.

# Express server
PORT=5000
NODE_ENV=development

# Frontend API host used by lib/query-client.ts.
# Production/release builds must point at the deployed API host, not localhost.
EXPO_PUBLIC_DOMAIN=localhost:5000

# Server CORS allowlist for browser clients in production.
# Use exact frontend origins, including scheme and port if present.
# Separate multiple origins with commas. Do not include paths or trailing slashes.
# Local development can usually leave this unset because localhost is allowed
# when NODE_ENV is not production.
CORS_ALLOWED_ORIGINS=https://your-frontend.example.com,https://www.your-frontend.example.com

# Supabase Auth + progress sync.
# These are publishable frontend values. Do not put service_role or secret keys
# in EXPO_PUBLIC_* variables.
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=

# AI and speech providers
AI_INTEGRATIONS_OPENAI_API_KEY=
# Optional alias used by many hosts/tools. The server accepts either name.
OPENAI_API_KEY=
AZURE_SPEECH_KEY=
AZURE_SPEECH_REGION=
GOOGLE_TTS_API_KEY=

# ── DeepSeek (primary text LLM when set) ─────────────────────────────────────
# When DEEPSEEK_API_KEY is present, DeepSeek-V3 (deepseek-chat) becomes the
# PRIMARY provider for completeText() — chat / npc-chat / mission-chat /
# writing-eval / translate / quiz / pronunciation-coach / word-lookup, etc.
# It is ~10x cheaper than gpt-4o with comparable tutor-task quality across
# KO/EN/ES/ID (see scripts/llm-eval.mjs), and OpenAI → Claude remain automatic
# fallbacks. Vision (handwriting) and moderation stay on OpenAI.
# Leave unset to keep the prior OpenAI-first behavior (zero change).
DEEPSEEK_API_KEY=
# Optional overrides (defaults shown):
# DEEPSEEK_MODEL=deepseek-chat
# DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# Database, when the server storage layer is backed by PostgreSQL.
DATABASE_URL=

# ── Stripe (Pro subscription) ────────────────────────────────────────────────
# Leave these unset until you're ready to activate billing — the server returns
# `{ url: null, error: "Stripe not configured" }` for /api/billing/checkout
# and /api/billing/portal in that case, and the client renders a polite
# "결제 시스템 준비 중 / Billing coming soon" placeholder.
#
# Activation steps live in server/billing.ts header. TL;DR:
#   1. npm install stripe
#   2. Uncomment the `import Stripe from "stripe"` line in server/billing.ts
#   3. Run the linguaai_user_subscriptions migration
#   4. Set the four env vars below
#   5. Add a webhook in the Stripe dashboard → <api-host>/api/billing/webhook
#
# STRIPE_SECRET_KEY      — sk_test_... or sk_live_... (never commit)
# STRIPE_WEBHOOK_SECRET  — whsec_... shown after creating the webhook endpoint
# STRIPE_PRICE_ID        — price_... for the $4.99/mo Pro plan (one per currency
#                          if you also configure ₩5,900/mo via Adaptive Pricing)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID=
