# Local/deployment environment template.
# Copy values into your local .env or your hosting provider's environment settings.

# Express server
PORT=5000
NODE_ENV=development

# Frontend API host used by lib/query-client.ts.
# Production/release builds must point at the deployed API host, not localhost.
EXPO_PUBLIC_DOMAIN=localhost:5000

# Server CORS allowlist for browser clients in production.
# Use exact frontend origins, including scheme and port if present.
# Separate multiple origins with commas. Do not include paths or trailing slashes.
# Local development can usually leave this unset because localhost is allowed
# when NODE_ENV is not production.
CORS_ALLOWED_ORIGINS=https://your-frontend.example.com,https://www.your-frontend.example.com

# Supabase Auth + progress sync.
# These are publishable frontend values. Do not put service_role or secret keys
# in EXPO_PUBLIC_* variables.
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=

# AI and speech providers
AI_INTEGRATIONS_OPENAI_API_KEY=
# Optional alias used by many hosts/tools. The server accepts either name.
OPENAI_API_KEY=
AZURE_SPEECH_KEY=
AZURE_SPEECH_REGION=
GOOGLE_TTS_API_KEY=

# Database, when the server storage layer is backed by PostgreSQL.
DATABASE_URL=
