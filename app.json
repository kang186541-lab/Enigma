{
  "expo": {
    "name": "Enigma Language Adventure",
    "slug": "enigma",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "enigma",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#1a0a05"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.enigma.app",
      "infoPlist": {
        "NSMicrophoneUsageDescription": "발음 연습을 위해 마이크가 필요해요",
        "NSSpeechRecognitionUsageDescription": "발음 평가를 위해 음성 인식이 필요해요"
      }
    },
    "android": {
      "package": "com.enigma.app",
      "usesCleartextTraffic": true,
      "permissions": [
        "RECORD_AUDIO",
        "WRITE_EXTERNAL_STORAGE",
        "READ_EXTERNAL_STORAGE",
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS"
      ],
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundColor": "#1a0a05"
      }
    },
    "web": {
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      [
        "expo-router",
        {
          "origin": "https://enigma-production-ea19.up.railway.app"
        }
      ],
      "expo-font",
      "expo-web-browser",
      [
        "expo-av",
        {
          "microphonePermission": "발음 연습을 위해 마이크가 필요해요"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {
        "origin": "https://enigma-production-ea19.up.railway.app"
      },
      "eas": {
        "projectId": "e368a20b-e6fb-46b2-b059-ee12f642f9f7"
      }
    },
    "owner": "franksoul",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/e368a20b-e6fb-46b2-b059-ee12f642f9f7"
    }
  }
}
